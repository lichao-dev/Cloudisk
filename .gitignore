# 忽略编辑器或操作系统自动生成的文件
.DS_Store
Thumbs.db
*~

# 忽略 Vim/Emacs 等产生的临时文件
.*.swp
.*.swo
*.un~

# -----------------------------
# C/C++编译相关
# -----------------------------

# 忽略编译产物（目标文件、库、可执行文件等）
*.o
*.obj
*.so
*.a
*.out
*.exe

# 依赖文件或构建中产生的其他临时文件
.depend
*.d

# -----------------------------
# 项目目录
# -----------------------------

# 忽略编译生成的二进制文件和对象文件
bin/*
# 如果需要保留 bin 目录下某些子文件夹，可在此添加 “!bin/xxx/” 的例外规则

# 日志目录
logs/*
# 如果需要保留 logs 目录结构，可以改成 “logs/*” 但保留空目录

sync.sh

